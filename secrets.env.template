# secrets.env.template
# Copy this file to secrets.env and fill in the values.
# secrets.env is gitignored — never commit it.
#
# UPLOAD_API_KEY: The Bearer token checked by the Cloudflare Worker (terraton-ingest).
# Set this in Cloudflare → Workers → terraton-ingest → Settings → Variables → API_SECRET.

UPLOAD_API_KEY=your-api-secret-here
